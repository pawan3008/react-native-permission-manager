{
  "name": "react-native-permission-manager",
  "version": "0.2.4",
  "description": "React Native permissions helper for Android and iOS — check, request, ensure, hooks, and a PermissionGate.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/commonjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "docs/banner.png",
    "react-native-permission-manager.podspec",
    "!ios/build",
    "!android/build",
    "!android/.gradle",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib android/build example/android/build",
    "prepare": "bob build",
    "release": "release-it",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":80,\"functions\":80,\"lines\":80,\"statements\":80}}'",
    "codegen": "react-native codegen",
    "example": "yarn --cwd example",
    "pods": "cd example/ios && pod install"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "permissions",
    "permission-manager",
    "turbo-module",
    "turbomodule",
    "new-architecture",
    "fabric",
    "codegen"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pawan3008/react-native-permission-manager.git"
  },
  "author": "Pawan Vishwakarma <rockpv30@gmail.com> (https://github.com/pawan3008)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pawan3008/react-native-permission-manager/issues"
  },
  "homepage": "https://github.com/pawan3008/react-native-permission-manager#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@react-native-community/cli": "^15.0.0",
    "@react-native/eslint-config": "^0.75.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "del-cli": "^5.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "react": "18.3.1",
    "react-native": "0.75.0",
    "react-native-builder-bob": "^0.30.0",
    "release-it": "^17.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@3.6.4",
  "codegenConfig": {
    "name": "RNPermissionManagerSpec",
    "type": "modules",
    "jsSrcsDir": "src/native",
    "android": {
      "javaPackageName": "com.permissionmanager"
    },
    "ios": {}
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
